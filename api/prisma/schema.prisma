// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  cpf       String   @unique
  password  String
  address   String?
  role      String   @default("CLIENT") // CLIENT or ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  tickets       Ticket[]
  invoices      Invoice[]
  notifications Notification[]
}

model Plan {
  id          String   @id @default(uuid())
  name        String
  price       Float
  category    String   // Residencial, Comercial, Combo
  speed       String?
  features    String
  popular     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id              String   @id @default(uuid())
  userId          String
  planId          String
  status          String   @default("PENDING_INSTALL") // PENDING_INSTALL, ACTIVE, CANCELLED
  cep             String
  houseNumber     String
  reference       String?
  paymentMethod   String   // PIX, BOLETO
  installationDate DateTime? // null = equipe ainda não agendou
  installationTime String?   // ex: "08:00-12:00"
  startDate       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  installationOptions String? // JSON array of proposed slots
  assignedTechId   String?  // Employee ID of assigned technician
  assignedTechName String?  // Cached tech name for quick display
  wifiSsid        String?  @default("Familia_Plus_5G")
  wifiPassword    String?  @default("changeme123")

  user            User     @relation(fields: [userId], references: [id])
  plan            Plan     @relation(fields: [planId], references: [id])
  cancellation    Cancellation?
}

model Ticket {
  id              String   @id @default(uuid())
  userId          String
  subject         String
  message         String
  status          String   @default("OPEN") // OPEN, WAITING_USER, SCHEDULED, RESOLVED
  visitOptions    String?  // Armazena JSON com os horários propostos pelo admin
  visitScheduled  String?  // Armazena o horário escolhido pelo cliente
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
}

model Invoice {
  id            String   @id @default(uuid())
  userId        String
  amount        Float
  dueDate       DateTime
  status        String   @default("PENDING") // PENDING, PAID, OVERDUE
  pixCode       String?  // Mocked pix code
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model Employee {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SUPPORT") // ADMIN, SUPPORT, TECH, FINANCE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Future relations like handled tickets could go here
}

model Cancellation {
  id              String   @id @default(uuid())
  subscriptionId  String   @unique
  reason          String
  fineAmount      Float    @default(0.0)
  equipmentStatus String   @default("PENDING_PICKUP") // PENDING_PICKUP, PICKED_UP
  createdAt       DateTime @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  // null = broadcast/global alert (e.g. Zabbix)
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("INFO") // MAINTENANCE, BILLING, INFO
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}
